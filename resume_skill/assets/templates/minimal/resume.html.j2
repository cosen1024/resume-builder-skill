<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ meta.name }} · 简历</title>
<style>{{ css }}</style>
</head>
<body>
<div class="page">
  <header class="hd">
    {% if meta.photo %}<img class="photo" src="{{ meta.photo }}" alt="photo">{% endif %}
    <div class="hd-main">
      <h1 class="name">{{ meta.name }}</h1>
      {% if meta.intent %}<div class="intent">{{ meta.intent }}</div>{% endif %}
      {% if meta.intent_detail %}<div class="intent-detail">{{ meta.intent_detail }}</div>{% endif %}
    </div>
    <div class="hd-contact">
      {% if meta.phone %}<div>{{ meta.phone }}</div>{% endif %}
      {% if meta.email %}<div>{{ meta.email }}</div>{% endif %}
      {% if meta.location %}<div>{{ meta.location }}</div>{% endif %}
      {% if meta.gender or meta.birth %}<div>{{ [meta.gender, meta.birth] | select | join(' · ') }}</div>{% endif %}
    </div>
  </header>
  {% if meta.summary %}<p class="summary">{{ meta.summary }}</p>{% endif %}

  {% for sec in sections %}
  <section class="sec">
    <h2 class="sec-title">{{ sec.title }}</h2>
    {% if sec.bullets %}
    <ul class="plain">{% for b in sec.bullets %}<li>{{ b }}</li>{% endfor %}</ul>
    {% endif %}
    {% for e in sec.entries %}
    <div class="entry">
      <div class="entry-head">
        <span class="entry-title">
          {% if e.title_parts %}<strong>{{ e.title_parts[0] }}</strong>{% endif %}
          {% if e.title_parts|length > 1 %}<span class="entry-sub">{{ e.title_parts[1:] | join(' · ') }}</span>{% endif %}
        </span>
        {% if e.meta %}<span class="entry-meta">{{ e.meta }}</span>{% endif %}
      </div>
      {% if e.bullets %}<ul>{% for b in e.bullets %}<li>{{ b }}</li>{% endfor %}</ul>{% endif %}
    </div>
    {% endfor %}
  </section>
  {% endfor %}
</div>
</body>
</html>
